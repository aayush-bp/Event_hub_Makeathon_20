            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Advanced React Workshop\",\n  \"description\": \"Learn advanced React patterns and hooks\",\n  \"type\": \"Tech\",\n  \"dateTime\": \"2024-03-10T10:00:00Z\",\n  \"duration\": 120,\n  \"location\": \"Tech Center, Room A\",\n  \"maxParticipants\": 50\n}"
